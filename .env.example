# ============================================================
# Jira Configuration
# ============================================================
# Your Jira Cloud instance URL (e.g., https://yourcompany.atlassian.net)
JIRA_SERVER=https://yourcompany.atlassian.net

# Your Jira account email address
JIRA_EMAIL=your.email@company.com

# Generate an API token from:
# https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_API_TOKEN=your_jira_api_token_here

# ============================================================
# Target Portal Credentials
# ============================================================
# URL of the Sangraha LTFinance portal
PORTAL_URL=https://sangraha.ltfinance.com

# Portal login credentials
PORTAL_USERNAME=your_portal_username
PORTAL_PASSWORD=your_portal_password

# ============================================================
# Session Management
# ============================================================
# Path to save/load the browser session state (cookies + localStorage)
# This file is created automatically after your first manual login.
SESSION_STATE_FILE=session_state.json
